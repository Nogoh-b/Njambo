# Firebase (Auth + Messaging uniquement — les données vivent dans le backend VPS)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=njambo.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=njambo
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=njambo.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id_here
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_web_push_vapid_key

# Backend VPS (server/) : API HTTP /api/:command + WebSocket /ws
# En dev local : http://localhost:8081 ; en prod : https://api.votre-domaine
NEXT_PUBLIC_BACKEND_URL=http://localhost:8081

# Table overlays / callouts readability (ms)
# Utilisé pour: "À TOI", "NJAMBO", "NGATA GAGNÉ", activation carte boost...
NEXT_PUBLIC_NJ_TABLE_READABILITY_MS=2900
NEXT_PUBLIC_NJ_POWER_OVERLAY_MS=3600

# ── server/ (backend VPS, à définir dans server/.env — non commité) ──
# DATABASE_URL=postgres://njambo:motdepasse@localhost:5432/njambo
# GOOGLE_APPLICATION_CREDENTIALS=/opt/njambo/service-account.json
# PORT=8081

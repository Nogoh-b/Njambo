{
  "name": "njambo-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:rules": "set XDG_CONFIG_HOME=.firebase-config&& firebase emulators:exec --only firestore,auth \"vitest run tests/firestore.rules.test.ts\"",
    "build:functions": "npm --prefix functions run build",
    "emulators": "firebase emulators:start --only auth,firestore,functions"
  },
  "dependencies": {
    "@tsparticles/engine": "^4.3.1",
    "@tsparticles/preset-confetti": "^4.3.1",
    "@tsparticles/react": "^4.3.1",
    "@tsparticles/slim": "^4.3.1",
    "firebase": "^12.15.0",
    "gsap": "^3.15.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "firebase-tools": "^15.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}

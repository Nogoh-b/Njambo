# ═══════════════ Triches de DÉVELOPPEMENT (Njambo) ═══════════════
# Copier ce fichier en `.env.local` puis REDÉMARRER le serveur dev
# (les variables NEXT_PUBLIC_* sont inlinées au build).
# Tout est inactif tant que NEXT_PUBLIC_DEV_MODE n'est pas à 1 → zéro impact prod.

# Master switch : active les triches ci-dessous
NEXT_PUBLIC_DEV_MODE=1

# Équiper TOUTES les cartes pouvoir en jeu
NEXT_PUBLIC_DEV_ALL_POWERS=1

# …ou n'en équiper que N (prioritaire sur ALL_POWERS). La barre in-game scrolle.
# NEXT_PUBLIC_DEV_POWER_COUNT=6

# Réutilisation illimitée des cartes pouvoir (pas de « déjà utilisée »)
NEXT_PUBLIC_DEV_UNLIMITED_POWERS=1

# Timer de tour désactivé (temps illimité)
NEXT_PUBLIC_DEV_UNLIMITED_TIME=1

# Solde figé (F). 0 ou absent = désactivé.
NEXT_PUBLIC_DEV_RICH_BALANCE=1000000

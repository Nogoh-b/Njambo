{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022", "ES2022.Intl", "DOM"],
    "outDir": "dist",
    "rootDir": "..",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "../functions/src/**/*.ts", "../domain/**/*.ts"],
  "exclude": ["dist", "node_modules", "../functions/node_modules"]
}
